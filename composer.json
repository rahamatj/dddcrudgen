{
	"name": "raham/dddcrudgen",
	"version": "1.0.0",
	"description": "A Laravel package for DDD CRUD generation.",
	"autoload": {
		"psr-4": {
			"Raham\\DDDCRUDGen\\": "src/"
		}
	},
	"authors": [
		{
			"name": "rahamatj",
			"email": "32268831+rahamatj@users.noreply.github.com"
		}
	],
	"minimum-stability": "stable",
	"prefer-stable": true,
	"require": {
		"php": "^8.0"
	},
	"extra": {
		"laravel": {
			"providers": [
				"Raham\\DDDCRUDGen\\DDDCRUDGeneratorServiceProvider"
			]
		}
	}
}